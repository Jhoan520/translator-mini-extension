{
    "name": "Translator Extension",
    "description": "Extension for an easy and cozzy translation in the browser",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "translator_popup.html",
        "default_title": "Click to active the Translator",
        "default_icon": {
            "16": "images/icon-dark-16.png",
            "24": "images/icon-dark-24.png",
            "32": "images/icon-dark-32.png"
        }
    },
    "permissions": ["activeTab", "scripting", "storage"],
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["content.js"]
    }],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
        "resources": [ "css/translator-ext.css"],
        "matches": [ "<all_urls>" ]
        }
    ]
}